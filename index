<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>

  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700;800&display=swap" rel="stylesheet">
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="glass hero-box">

    <div class="left">
      <h1>Habib Nuran Mulkan</h1>
      <p>Mahasiswa Informatika • UI/UX Enthusiast • Future Developer</p>

      <div class="btn-group">
        <button onclick="openSection('bio')">Biodata</button>
        <button onclick="openSection('family')">Family</button>
        <button onclick="openSection('hobi')">Hobi</button>
        <button onclick="openSection('cita')">Cita-cita</button>
        <button onclick="openSection('daily')">Daily</button>
        <button onclick="openSection('gallery')">Gallery</button>
        <button onclick="toggleMusic()">🎵 Music</button>
      </div>
    </div>

    <div class="right">
      <img src="assets/img/profile.jpg" alt="profile">
    </div>

  </div>
</section>

<!-- OVERLAY CONTENT -->
<div id="overlay">

  <div class="content-box glass" id="bio">
    <h2>Biodata</h2>
    <p>Nama: Habib Nuran Mulkan</p>
    <p>NPM: 2408107010109</p>
    <p>Prodi: Informatika</p>
    <p>Kota: Banda Aceh</p>
    <p>Fokus pada pengembangan web modern dan UI/UX design.</p>
  </div>

  <div class="content-box glass" id="family">
    <h2>Family</h2>
    <pre>
Ayah : Leman
Ibu : Hafifah
Anak Pertama : Habib Nuran Mulkan
Anak Kedua : Muhammad Abrisam Altaf
    </pre>
  </div>

  <div class="content-box glass" id="hobi">
    <h2>Hobi</h2>
    <ul>
      <li>⚽ Futsal</li>
      <li>🎮 Gaming</li>
      <li>🎵 Musik</li>
      <li>🎬 Nonton Film</li>
    </ul>
  </div>

  <div class="content-box glass" id="cita">
    <h2>Cita-cita</h2>
    <p>Menjadi Orang Kaya.</p>
  </div>

  <div class="content-box glass" id="daily">
    <h2>Daily Activities</h2>
    <p>Pagi: Kuliah</p>
    <p>Siang: Istirahat</p>
    <p>Malam: Eksplor teknologi & hiburan sambil ngopi</p>
  </div>

  <div class="content-box glass" id="gallery">
    <h2>Gallery</h2>
    <img src="assets/img/profile.jpg" class="gallery-img">
    <p>Dokumentasi aktivitas</p>
  </div>

</div>

<!-- AUDIO -->
<audio id="audioPlayer">
  <source src="assets/music/music.mp3" type="audio/mpeg">
</audio>

<!-- MUSIC BAR PRO -->
<div id="musicBar" class="music-bar">

  <div class="music-info">
    <div class="cover"></div>
    <div>
      <h4>My Music</h4>
      <p id="musicStatus">Paused</p>
    </div>
  </div>

  <div class="player">
    <button id="playBtn" onclick="toggleMusic()">▶</button>
    <input type="range" id="progress" value="0">
    <div class="time">
      <span id="current">0:00</span> /
      <span id="duration">0:00</span>
    </div>
  </div>

  <div class="volume">
    🔊
    <input type="range" id="volume" min="0" max="1" step="0.01">
  </div>

  <div class="equalizer" id="eq">
    <span></span><span></span><span></span><span></span>
  </div>

</div>

<script src="script.js"></script>
</body>
</html>